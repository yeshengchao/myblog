&lt;style&gt;
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body {
    height: 100%;
    font-family: -apple-system, BlinkMacSystemFont, &#34;PingFang SC&#34;, &#34;Microsoft YaHei&#34;, sans-serif;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
