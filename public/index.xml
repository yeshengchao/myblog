      <description>&lt;!DOCTYPE html&gt;
&lt;html lang=&#34;zh-CN&#34;&gt;
&lt;head&gt;
&lt;meta charset=&#34;UTF-8&#34;&gt;
&lt;meta name=&#34;viewport&#34; content=&#34;width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no&#34;&gt;
&lt;title&gt;即将跳转到胜超影视站...&lt;/title&gt;
&lt;style&gt;
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body {
    height: 100%;
    font-family: -apple-system, BlinkMacSystemFont, &#34;PingFang SC&#34;, &#34;Microsoft YaHei&#34;, sans-serif;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: #fff;
    -webkit-font-smoothing: antialiased;
  }
  .wrap {
    min-height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px;
    text-align: center;
  }
  h1 {
    font-size: 1.4rem;
    font-weight: 500;
    margin-bottom: 28px;
    opacity: .92;
  }
  .count {
    font-size: 5rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 28px;
    text-shadow: 0 4px 20px rgba(0,0,0,.2);
  }
  .tip {
    font-size: .95rem;
    opacity: .8;
    margin-bottom: 32px;
  }
  a.btn {
    display: inline-block;
    padding: 12px 28px;
    background: rgba(255,255,255,.18);
    border: 1px solid rgba(255,255,255,.35);
    border-radius: 999px;
    color: #fff;
    text-decoration: none;
    font-size: .95rem;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    transition: background .2s;
  }
  a.btn:active { background: rgba(255,255,255,.3); }
  @media (max-width: 480px) {
    .count { font-size: 4rem; }
    h1 { font-size: 1.2rem; }
  }
&lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
  &lt;div class=&#34;wrap&#34;&gt;
    &lt;h1&gt;即将跳转到胜超影视站：film.shengchao.vip&lt;/h1&gt;
    &lt;div class=&#34;count&#34; id=&#34;count&#34;&gt;10&lt;/div&gt;
    &lt;div class=&#34;tip&#34;&gt;页面将在 &lt;span id=&#34;sec&#34;&gt;10&lt;/span&gt; 秒后自动跳转&lt;/div&gt;
    &lt;a class=&#34;btn&#34; href=&#34;https://film.shengchao.vip/&#34;&gt;立即跳转&lt;/a&gt;
  &lt;/div&gt;
&lt;script&gt;
  var url = &#34;https://film.shengchao.vip/&#34;;
  var n = 10;
  var elCount = document.getElementById(&#34;count&#34;);
  var elSec = document.getElementById(&#34;sec&#34;);
  var t = setInterval(function () {
    n--;
    if (n &lt;= 0) {
      clearInterval(t);
      location.replace(url);
      return;
    }
    elCount.textContent = n;
    elSec.textContent = n;
  }, 1000);
&lt;/script&gt;
&lt;/body&gt;
&lt;/html&gt;</description>
