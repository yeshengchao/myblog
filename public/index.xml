    font-weight: 700;
    line-height: 1;
    margin-bottom: 28px;
    text-shadow: 0 4px 20px rgba(0,0,0,.2);
  }
  .tip {
    font-size: .95rem;
    opacity: .8;
    margin-bottom: 32px;
  }
  a.btn {
    display: inline-block;
    padding: 12px 28px;
    background: rgba(255,255,255,.18);
    border: 1px solid rgba(255,255,255,.35);
    border-radius: 999px;
    color: #fff;
    text-decoration: none;
