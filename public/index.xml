    &lt;a class=&#34;btn&#34; href=&#34;https://film.shengchao.vip/&#34;&gt;立即跳转&lt;/a&gt;
  &lt;/div&gt;
&lt;script&gt;
  var url = &#34;https://film.shengchao.vip/&#34;;
  var n = 10;
  var elCount = document.getElementById(&#34;count&#34;);
  var elSec = document.getElementById(&#34;sec&#34;);
  var t = setInterval(function () {
    n--;
    if (n &lt;= 0) {
      clearInterval(t);
      location.replace(url);
      return;
    }
    elCount.textContent = n;
    elSec.textContent = n;
  }, 1000);
&lt;/script&gt;
